{
  "name": "secondop-backend",
  "version": "1.0.0",
  "description": "Backend API for SecondOp Medical Second Opinion Platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "dev:development": "bash scripts/with-env.sh .env.development nodemon src/server.ts",
    "dev:test": "bash scripts/with-env.sh .env.test nodemon src/server.ts",
    "dev:production": "bash scripts/with-env.sh .env.production nodemon src/server.ts",
    "build": "tsc",
    "build:development": "bash scripts/with-env.sh .env.development tsc",
    "build:test": "bash scripts/with-env.sh .env.test tsc",
    "build:production": "bash scripts/with-env.sh .env.production tsc",
    "start": "node dist/server.js",
    "start:development": "bash scripts/with-env.sh .env.development node dist/server.js",
    "start:test": "bash scripts/with-env.sh .env.test node dist/server.js",
    "start:production": "bash scripts/with-env.sh .env.production node dist/server.js",
    "db:setup": "bash scripts/setup-db.sh",
    "db:migrate": "psql -d $DB_NAME -f migrations/001_initial_schema.sql && psql -d $DB_NAME -f migrations/002_cases_and_messages.sql && psql -d $DB_NAME -f migrations/003_prescriptions_and_labs.sql && psql -d $DB_NAME -f migrations/004_billing_and_payments.sql && psql -d $DB_NAME -f migrations/005_case_analysis_and_intake.sql && psql -d $DB_NAME -f migrations/006_agent_analysis_runs.sql && psql -d $DB_NAME -f migrations/007_agentic_shadow_results.sql && psql -d $DB_NAME -f migrations/008_case_analysis_artifacts.sql && psql -d $DB_NAME -f migrations/009_dicom_imaging_and_annotations.sql",
    "db:setup:development": "bash scripts/with-env.sh .env.development bash scripts/setup-db.sh",
    "db:setup:test": "bash scripts/with-env.sh .env.test bash scripts/setup-db.sh",
    "db:setup:production": "bash scripts/with-env.sh .env.production bash scripts/setup-db.sh",
    "db:migrate:development": "bash scripts/with-env.sh .env.development npm run db:migrate",
    "db:migrate:test": "bash scripts/with-env.sh .env.test npm run db:migrate",
    "db:migrate:production": "bash scripts/with-env.sh .env.production npm run db:migrate",
    "db:seed": "psql -d $DB_NAME -f scripts/seed-data.sql",
    "db:seed:development": "bash scripts/with-env.sh .env.development npm run db:seed",
    "db:seed:test": "bash scripts/with-env.sh .env.test npm run db:seed",
    "db:seed:production": "bash scripts/with-env.sh .env.production npm run db:seed",
    "db:reset": "npm run db:setup && npm run db:seed",
    "e2e:smoke": "node scripts/e2e-smoke.mjs",
    "e2e:smoke:analysis": "E2E_ENABLE_ANALYSIS=true node scripts/e2e-smoke.mjs",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "medical",
    "telemedicine",
    "second-opinion",
    "healthcare"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "aws-sdk": "^2.1498.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "date-fns": "^3.0.0",
    "dicom-parser": "^1.8.21",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^6.9.7",
    "openai": "^4.104.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.11.3",
    "pg-boss": "^10.1.6",
    "pg-pool": "^3.6.1",
    "socket.io": "^4.6.0",
    "stripe": "^14.7.0",
    "twilio": "^4.19.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.4",
    "@types/nodemailer": "^6.4.14",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "node-pg-migrate": "^6.2.2",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}

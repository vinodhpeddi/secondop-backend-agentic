# Server Configuration
NODE_ENV=test
PORT=5001
API_VERSION=v1

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=secondop_test_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# JWT Configuration
JWT_SECRET=test_jwt_secret_change_me
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=test_refresh_secret_change_me
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=12

# CORS
CORS_ORIGIN=http://localhost:8080
SOCKET_IO_CORS_ORIGIN=http://localhost:8080

# AI / Agentic
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_MS=60000
ANALYSIS_AGENTIC_MODE=off
AGENTIC_MODEL=gpt-4.1-mini
AGENTIC_MAX_STEPS=8
AGENTIC_MAX_REFINEMENTS=1
AGENTIC_RUNTIME=native
AGENTIC_LANGCHAIN_ALLOW_FALLBACK=true
ANALYSIS_QUEUE_NAME=case-analysis-baseline
ANALYSIS_QUEUE_SCHEMA=pgboss


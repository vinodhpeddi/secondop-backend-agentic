# Server Configuration
NODE_ENV=production
PORT=5000
API_VERSION=v1

# Database Configuration
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_SSL=true

# JWT Configuration
JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=12

# CORS
CORS_ORIGIN=
SOCKET_IO_CORS_ORIGIN=

# AI / Agentic
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_MS=60000
ANALYSIS_AGENTIC_MODE=shadow
AGENTIC_MODEL=gpt-4.1-mini
AGENTIC_MAX_STEPS=8
AGENTIC_MAX_REFINEMENTS=1
AGENTIC_RUNTIME=native
AGENTIC_LANGCHAIN_ALLOW_FALLBACK=true
ANALYSIS_QUEUE_NAME=case-analysis-baseline
ANALYSIS_QUEUE_SCHEMA=pgboss

